<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KRecords" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@drawable/bg_screen</item>
        <item name="android:textColorPrimary">@color/kr_text_primary</item>
        <item name="android:textColorSecondary">@color/kr_text_secondary</item>
    </style>

    <style name="Widget.KRecords.PrimaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_primary_button</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
    </style>

    <style name="Widget.KRecords.SecondaryButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_secondary_button</item>
        <item name="android:textColor">@color/kr_text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
    </style>
</resources>
